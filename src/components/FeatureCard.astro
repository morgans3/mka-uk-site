---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description } = Astro.props;
---

<div class="bg-white rounded-xl border border-gray-100 p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow">
  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center mb-4">
    <slot name="icon">
      <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </slot>
  </div>
  <h3 class="text-lg font-heading font-bold text-dark mb-2">{title}</h3>
  <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
</div>
