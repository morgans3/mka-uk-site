---
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  slug: string;
  image?: string;
}

const { title, date, excerpt, slug, image } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a href={`${base}/news/${slug}`} class="block group">
  <article class="bg-white rounded-xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow">
    {image ? (
      <img src={`${base}/${image.replace(/^\//, '')}`} alt="" class="w-full aspect-[16/9] object-cover" loading="lazy" />
    ) : (
      <div class="w-full aspect-[16/9] bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center">
        <svg class="w-10 h-10 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </div>
    )}
    <div class="p-5">
      <time class="text-xs text-gray-500 font-medium">{formattedDate}</time>
      <h3 class="font-heading font-bold text-dark mt-1 group-hover:text-primary-600 transition-colors">
        {title}
      </h3>
      <p class="text-gray-600 text-sm mt-2 leading-relaxed">{excerpt}</p>
    </div>
  </article>
</a>
