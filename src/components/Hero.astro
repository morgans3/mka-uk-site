---
interface Props {
  title: string;
  subtitle?: string;
  fullHeight?: boolean;
  showCta?: boolean;
  ctaText?: string;
  ctaHref?: string;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  fullHeight = false,
  showCta = false,
  ctaText = 'Get Started',
  ctaHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/contact`,
  backgroundImage,
} = Astro.props;
---

{fullHeight ? (
  <!-- Homepage hero: full viewport, dark overlay, centered content -->
  <section class="relative min-h-[80vh] md:min-h-screen flex items-center justify-center bg-dark overflow-hidden">
    {backgroundImage ? (
      <img
        src={`${import.meta.env.BASE_URL}images/${backgroundImage}`}
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark-light to-primary-900/30"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    )}

    <div class="relative z-10 text-center px-4 max-w-3xl mx-auto">
      <img
        src={`${import.meta.env.BASE_URL}images/badge-clear-bg.png`}
        alt=""
        class="w-24 h-24 md:w-32 md:h-32 mx-auto mb-6"
      />
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white mb-4 md:mb-6">
        {title}
      </h1>
      {subtitle && (
        <p class="text-base sm:text-lg md:text-xl text-gray-300 mb-8 max-w-xl mx-auto">
          {subtitle}
        </p>
      )}
      {showCta && (
        <a
          href={ctaHref}
          class="inline-flex items-center px-6 py-3 md:px-8 md:py-4 bg-primary-500 hover:bg-primary-600 text-white font-semibold rounded-lg transition-colors text-base md:text-lg"
        >
          {ctaText}
        </a>
      )}
    </div>
  </section>
) : (
  <!-- Inner page hero: red banner -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-500 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 md:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white mb-3">
        {title}
      </h1>
      {subtitle && (
        <p class="text-base md:text-lg text-white/80 max-w-xl mx-auto">
          {subtitle}
        </p>
      )}
    </div>
  </section>
)}
