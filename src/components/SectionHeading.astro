---
interface Props {
  label?: string;
  heading: string;
  subtitle?: string;
  centered?: boolean;
}

const { label, heading, subtitle, centered = true } = Astro.props;
---

<div class:list={['mb-8 md:mb-12', centered && 'text-center']}>
  {label && (
    <span class="inline-block text-primary-500 font-semibold text-sm uppercase tracking-wider mb-2">
      {label}
    </span>
  )}
  <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading font-bold text-dark">
    {heading}
  </h2>
  {subtitle && (
    <p class:list={['text-gray-600 mt-3 text-base md:text-lg', centered && 'max-w-2xl mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
