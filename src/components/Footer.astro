---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();

const quickLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/instructors', label: 'Our Instructors' },
  { href: '/products', label: 'Club Products' },
  { href: '/news', label: 'Latest News' },
  { href: '/contact', label: 'Contact Us' },
];
---

<footer class="bg-dark text-gray-300">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Column 1: Brand -->
      <div class="md:col-span-2 lg:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-3 mb-4">
          <img
            src={`${import.meta.env.BASE_URL}images/badge-clear-bg.png`}
            alt="Musuko Karate Academy"
            class="h-12 w-12"
          />
          <span class="font-heading font-bold text-white text-lg">
            Musuko Karate Academy
          </span>
        </a>
        <p class="text-sm text-gray-400 mb-6 max-w-xs">
          We offer a safe, friendly, disciplined environment to learn the traditional Japanese art of Shotokan.
        </p>
        <!-- Social links -->
        <div class="flex gap-4">
          <a
            href="https://www.facebook.com/musukokarateacademy/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={`${base}${link.href}`}
                class="text-sm text-gray-400 hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex gap-2">
            <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Poulton-le-Fylde, Lancashire, FY6 7EU</span>
          </li>
          <li class="flex gap-2">
            <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span>admin@musukokarateacademy.co.uk</span>
          </li>
          <li class="flex gap-2">
            <svg class="w-5 h-5 text-primary-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>07540 518377</span>
          </li>
        </ul>
      </div>

      <!-- Column 4: Training Times -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Training Times</h3>
        <ul class="space-y-2 text-sm text-gray-400">
          <li class="flex justify-between">
            <span>Monday</span>
            <span>6:00pm - 7:00pm</span>
          </li>
          <li class="flex justify-between">
            <span>Wednesday</span>
            <span>6:00pm - 7:00pm</span>
          </li>
          <li class="flex justify-between">
            <span>Saturday</span>
            <span>10:00am - 11:00am</span>
          </li>
        </ul>
        <p class="text-xs text-gray-500 mt-3">Check our contact page for full schedule</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-800 text-center text-sm text-gray-500">
      <p>&copy; {year} Musuko Karate Academy. All rights reserved.</p>
    </div>
  </div>
</footer>
