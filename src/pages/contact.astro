---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';

const timetable = [
  { day: 'Monday', time: '6:00pm - 7:00pm', level: 'All Levels', location: 'Venue TBC' },
  { day: 'Wednesday', time: '6:00pm - 7:00pm', level: 'All Levels', location: 'Venue TBC' },
  { day: 'Saturday', time: '10:00am - 11:00am', level: 'All Levels', location: 'Venue TBC' },
];
---

<BaseLayout title="Contact" description="Get in touch with Musuko Karate Academy. Find class times and contact details.">
  <Hero title="Contact Us" subtitle="Get in touch to find out more or come along to a class" />

  <!-- Contact Details -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="max-w-xl">
        <div>
          <h2 class="font-heading font-bold text-dark text-2xl mb-6">Get in Touch</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Location</h3>
                <p class="text-gray-600 text-sm mt-1">Poulton-le-Fylde, Lancashire, FY6 7EU</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Email</h3>
                <p class="text-gray-600 text-sm mt-1">admin@musukokarateacademy.co.uk</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Phone</h3>
                <p class="text-gray-600 text-sm mt-1">07540 518377</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Facebook</h3>
                <a
                  href="https://www.facebook.com/musukokarateacademy/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary-500 hover:text-primary-600 text-sm mt-1 inline-block transition-colors"
                >
                  Musuko Karate Academy
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timetable -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 md:px-8">
      <SectionHeading
        label="Schedule"
        heading="Class Timetable"
        subtitle="Come along to any of our sessions. First class is always free!"
      />

      <!-- Mobile cards -->
      <div class="md:hidden space-y-4">
        {timetable.map((session) => (
          <div class="bg-white rounded-lg p-4 shadow-sm">
            <div class="font-semibold text-dark">{session.day}</div>
            <div class="text-primary-500 font-medium text-sm mt-1">{session.time}</div>
            <div class="text-gray-600 text-sm mt-1">{session.level} &middot; {session.location}</div>
          </div>
        ))}
      </div>

      <!-- Desktop table -->
      <div class="hidden md:block bg-white rounded-xl overflow-hidden shadow-sm">
        <table class="w-full">
          <thead class="bg-dark text-white">
            <tr>
              <th class="px-6 py-4 text-left text-sm font-semibold">Day</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Time</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Level</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Location</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {timetable.map((session) => (
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 font-medium text-dark">{session.day}</td>
                <td class="px-6 py-4 text-primary-500 font-medium">{session.time}</td>
                <td class="px-6 py-4 text-gray-600">{session.level}</td>
                <td class="px-6 py-4 text-gray-600">{session.location}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="text-center text-gray-500 text-sm mt-6">
        Timetable is placeholder content. Update with real class schedule.
      </p>
    </div>
  </section>
</BaseLayout>
